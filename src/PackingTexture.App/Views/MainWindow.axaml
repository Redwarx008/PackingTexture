<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:PackingTexture.App.ViewModels"
        x:Class="PackingTexture.App.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        DragDrop.AllowDrop="True"
        DragDrop.Drop="Window_OnDrop"
        Title="PackingTexture"
        Width="1220"
        Height="760"
        MinWidth="1080"
        MinHeight="680"
        Background="#F8FAFC">
  <Design.DataContext>
    <vm:MainWindowViewModel />
  </Design.DataContext>

  <Window.Styles>
    <Style Selector="TextBlock.heading">
      <Setter Property="FontSize" Value="18" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Foreground" Value="#111827" />
    </Style>
    <Style Selector="TextBlock.muted">
      <Setter Property="Foreground" Value="#64748B" />
    </Style>
    <Style Selector="Border.panel">
      <Setter Property="Background" Value="#F8FAFC" />
      <Setter Property="BorderBrush" Value="#CBD5E1" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="8" />
    </Style>
    <Style Selector="Button.primary">
      <Setter Property="Background" Value="#0878DE" />
      <Setter Property="Foreground" Value="White" />
      <Setter Property="CornerRadius" Value="8" />
      <Setter Property="Padding" Value="16,0" />
      <Setter Property="MinHeight" Value="40" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>
    <Style Selector="Button.secondary">
      <Setter Property="Background" Value="White" />
      <Setter Property="Foreground" Value="#475569" />
      <Setter Property="BorderBrush" Value="#CBD5E1" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="8" />
      <Setter Property="Padding" Value="14,0" />
      <Setter Property="MinHeight" Value="40" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>
    <Style Selector="Button.ghost">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="Foreground" Value="#64748B" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="Padding" Value="2" />
    </Style>
    <Style Selector="Button.previewMode">
      <Setter Property="Background" Value="#0878DE" />
      <Setter Property="Foreground" Value="White" />
      <Setter Property="CornerRadius" Value="7" />
      <Setter Property="MinHeight" Value="34" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>
    <Style Selector="ComboBox">
      <Setter Property="MinHeight" Value="46" />
      <Setter Property="FontSize" Value="16" />
      <Setter Property="CornerRadius" Value="7" />
    </Style>
  </Window.Styles>

  <Grid ColumnDefinitions="570,*" RowDefinitions="*" Margin="28" ColumnSpacing="18">
    <Border Grid.Column="0" Classes="panel">
      <Grid RowDefinitions="Auto,Auto,*,Auto">
        <Grid Grid.Row="0" ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8" Margin="14,12,14,12">
          <TextBlock Classes="heading" Text="Sources &amp; Channel Packing" VerticalAlignment="Center" />
          <Button Grid.Column="1" Classes="secondary" Content="Clear" Command="{Binding ClearCommand}" />
          <Button Grid.Column="2" Classes="primary" Content="Add Images" Click="AddImages_OnClick" />
        </Grid>

        <Border Grid.Row="1"
                Background="#EAF4FF"
                BorderBrush="#CBD5E1"
                BorderThickness="0,1"
                Padding="14"
                MinHeight="54">
          <TextBlock Text="Drag PNG / TIF / TGA / BMP / JPG source images here"
                     FontSize="16"
                     Foreground="#5B6B7F"
                     HorizontalAlignment="Center"
                     VerticalAlignment="Center" />
        </Border>

        <ScrollViewer Grid.Row="2" Margin="14,14,14,12" VerticalScrollBarVisibility="Auto">
          <ItemsControl ItemsSource="{Binding SourceImages}">
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="vm:SourceImageViewModel">
                <Border Background="White"
                        BorderBrush="#D8E1EC"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="10"
                        Margin="0,0,0,12"
                        DragDrop.AllowDrop="True"
                        DragDrop.DragOver="SourceCard_OnDragOver"
                        DragDrop.Drop="SourceCard_OnDrop"
                        x:CompileBindings="False">
                  <Grid ColumnDefinitions="72,*,28" ColumnSpacing="12" MinHeight="74">
                    <Border Width="60" Height="60" CornerRadius="6" ClipToBounds="True" VerticalAlignment="Center">
                      <Image Source="{Binding ThumbnailBitmap}" Stretch="UniformToFill" />
                    </Border>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="3">
                      <TextBlock Text="{Binding FileName}"
                                 FontWeight="SemiBold"
                                 FontSize="15"
                                 Foreground="#111827"
                                 TextTrimming="CharacterEllipsis" />
                      <TextBlock Text="{Binding SourceSummary}"
                                 Classes="muted"
                                 FontSize="14"
                                 TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                    <Border Grid.Column="2"
                            Width="28"
                            Height="64"
                            Background="Transparent"
                            Cursor="SizeAll"
                            PointerPressed="SourceDragHandle_OnPointerPressed"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                      <TextBlock Text="≡"
                                 FontSize="20"
                                 FontWeight="SemiBold"
                                 Foreground="#64748B"
                                 HorizontalAlignment="Center"
                                 VerticalAlignment="Center"
                                 TextAlignment="Center" />
                    </Border>
                  </Grid>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </ScrollViewer>

        <Border Grid.Row="3" BorderBrush="#CBD5E1" BorderThickness="0,1,0,0" Padding="14,14,14,16">
          <StackPanel Spacing="10">
            <Grid ColumnDefinitions="*,Auto">
              <TextBlock Classes="heading" Text="Output Channels" />
              <TextBlock Grid.Column="1"
                         Classes="muted"
                         Text="Auto assigned from source order"
                         FontSize="14"
                         VerticalAlignment="Center" />
            </Grid>

            <Grid ColumnDefinitions="56,*,128" ColumnSpacing="10">
              <TextBlock Classes="muted" Text="OUT" FontWeight="SemiBold" />
              <TextBlock Grid.Column="1" Classes="muted" Text="SOURCE IMAGE" FontWeight="SemiBold" />
              <TextBlock Grid.Column="2" Classes="muted" Text="CHANNEL" FontWeight="SemiBold" />
            </Grid>

            <ItemsControl ItemsSource="{Binding Mappings}">
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="vm:ChannelMappingViewModel">
                  <Border Background="White"
                          BorderBrush="#D8E1EC"
                          BorderThickness="1"
                          CornerRadius="8"
                          Padding="8"
                          Margin="0,0,0,8"
                          IsEnabled="{Binding IsActiveForExport}"
                          Opacity="{Binding RowOpacity}"
                          x:CompileBindings="False">
                    <Grid ColumnDefinitions="56,*,128" ColumnSpacing="10">
                      <TextBlock Text="{Binding OutputChannel}"
                                 Foreground="{Binding OutputChannelBrush}"
                                 FontWeight="Bold"
                                 FontSize="24"
                                 HorizontalAlignment="Center"
                                 VerticalAlignment="Center" />
                      <ComboBox Grid.Column="1"
                                ItemsSource="{Binding SourceOptions}"
                                SelectedItem="{Binding SelectedSourceOption}"
                                HorizontalAlignment="Stretch">
                        <ComboBox.ItemTemplate>
                          <DataTemplate>
                            <TextBlock Text="{Binding DisplayName}" TextTrimming="CharacterEllipsis" />
                          </DataTemplate>
                        </ComboBox.ItemTemplate>
                      </ComboBox>
                      <ComboBox Grid.Column="2"
                                ItemsSource="{Binding AvailableSourceChannels}"
                                SelectedItem="{Binding SelectedSourceChannel}"
                                IsEnabled="{Binding SelectedSourceOption.IsSource}"
                                HorizontalAlignment="Stretch" />
                    </Grid>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </StackPanel>
        </Border>
      </Grid>
    </Border>

    <Border Grid.Column="1" Classes="panel">
      <Grid RowDefinitions="Auto,*,Auto,Auto">
        <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="14,12,14,12">
          <TextBlock Classes="heading" Text="Preview &amp; Export" />
          <TextBlock Grid.Column="1"
                     Text="{Binding OutputSizeText}"
                     Classes="muted"
                     FontSize="14"
                     VerticalAlignment="Center" />
        </Grid>

        <Border Grid.Row="1" BorderBrush="#CBD5E1" BorderThickness="0,1" Padding="14">
          <Grid>
            <Border CornerRadius="8"
                    ClipToBounds="True"
                    BorderBrush="#CBD5E1"
                    BorderThickness="1"
                    Background="#EEF3F8">
              <Image Source="{Binding CheckerboardBitmap}" Stretch="Fill" />
            </Border>
            <Image Source="{Binding PreviewBitmap}"
                   Stretch="Uniform"
                   MaxWidth="420"
                   MaxHeight="420"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center" />
          </Grid>
        </Border>

        <Grid Grid.Row="2" ColumnDefinitions="*,*,*,*,*" ColumnSpacing="8" Margin="14,10,14,12">
          <Button Grid.Column="0" Classes="previewMode" Content="RGBA" Click="PreviewMode_OnClick" Tag="Rgba" HorizontalAlignment="Stretch" />
          <Button Grid.Column="1" Classes="previewMode" Content="R" Click="PreviewMode_OnClick" Tag="R" HorizontalAlignment="Stretch" />
          <Button Grid.Column="2" Classes="previewMode" Content="G" Click="PreviewMode_OnClick" Tag="G" HorizontalAlignment="Stretch" />
          <Button Grid.Column="3" Classes="previewMode" Content="B" Click="PreviewMode_OnClick" Tag="B" HorizontalAlignment="Stretch" />
          <Button Grid.Column="4" Classes="previewMode" Content="A" Click="PreviewMode_OnClick" Tag="A" HorizontalAlignment="Stretch" />
        </Grid>

        <Border Grid.Row="3" BorderBrush="#CBD5E1" BorderThickness="0,1,0,0" Padding="14,14,14,14">
          <Grid RowDefinitions="Auto,Auto,Auto" ColumnDefinitions="*,*" ColumnSpacing="14" RowSpacing="12">
            <StackPanel Grid.Row="0" Grid.Column="0" Spacing="8">
              <TextBlock Text="Format" FontWeight="SemiBold" FontSize="16" Foreground="#111827" />
              <ComboBox ItemsSource="{Binding ExportFormatOptions}"
                        SelectedItem="{Binding SelectedExportFormatOption}"
                        HorizontalAlignment="Stretch" />
            </StackPanel>

            <StackPanel Grid.Row="0" Grid.Column="1" Spacing="6">
              <TextBlock Text="Options" FontWeight="SemiBold" FontSize="16" Foreground="#111827" />
              <CheckBox Content="Mipmaps" IsChecked="{Binding GenerateMipMaps}" />
              <CheckBox Content="Flip Y / green channel" IsChecked="{Binding FlipY}" />
            </StackPanel>

            <Border Grid.Row="1"
                    Grid.ColumnSpan="2"
                    IsVisible="{Binding HasStatusMessage}"
                    Background="#FFF7ED"
                    BorderBrush="#FDBA74"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="12">
              <TextBlock Text="{Binding StatusText}"
                         Foreground="#B45309"
                         TextWrapping="Wrap" />
            </Border>

            <Button Grid.Row="2"
                    Grid.ColumnSpan="2"
                    Classes="primary"
                    Content="Export"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"
                    MinHeight="44"
                    Click="Export_OnClick" />
          </Grid>
        </Border>
      </Grid>
    </Border>
  </Grid>
</Window>
